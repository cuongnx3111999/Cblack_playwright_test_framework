# Đây là file môi trường gốc dùng chung.
# Chú ý không đẩy file này (nếu chứa sensitive data) lên Repo (Nên setup .gitignore cho các file .env)
# Bạn có thể nhân bản thành .env.staging, .env.prod và dùng chung cấu hình lấy từ config/base.config.ts

NODE_ENV=development

# URLs cho Kiến trúc đa dự án
CRM_BASE_URL=https://crm.admin.example.com/
PORTAL_BASE_URL=https://portal.user.example.com/

# Thông tin tài khoản đăng nhập (Nếu không quản lý qua users.constants.ts, có thể đẩy ra ENV để bảo mật)
ADMIN_USER=admin@example.com
ADMIN_PASS=password123
